{"id":"tpch_seed_002_sort_limit","tables":{"orders":{"columns":{"o_orderkey":"Int64","o_custkey":"Int64","o_orderstatus":"Utf8","o_totalprice":"Float64","o_orderdate":"Date","o_orderpriority":"Utf8","o_clerk":"Utf8","o_shippriority":"Int64","o_comment":"Utf8"},"n_rows":15000}},"question":"Return the 10 orders with the highest total price, showing order key, total price, and order date.","reference_code":"result = (\n    orders\n    .sort(\"o_totalprice\", descending=True)\n    .head(10)\n    .select([\"o_orderkey\", \"o_totalprice\", \"o_orderdate\"])\n)","tags":["sort","limit","select"],"difficulty":1,"expected_output_hash":"2fa0b585770b9b4d511cf7c512537e4673aae1a4afb0305f25e0e49b0d8554e0","expected_n_rows":10,"expected_columns":["o_orderkey","o_totalprice","o_orderdate"]}
{"id":"tpch_seed_003_groupby_count","tables":{"orders":{"columns":{"o_orderkey":"Int64","o_custkey":"Int64","o_orderstatus":"Utf8","o_totalprice":"Float64","o_orderdate":"Date","o_orderpriority":"Utf8","o_clerk":"Utf8","o_shippriority":"Int64","o_comment":"Utf8"},"n_rows":15000}},"question":"Count the number of orders per order status, sorted alphabetically by status.","reference_code":"result = (\n    orders\n    .group_by(\"o_orderstatus\")\n    .agg(pl.len().alias(\"n_orders\"))\n    .sort(\"o_orderstatus\")\n)","tags":["groupby","agg"],"difficulty":1,"expected_output_hash":"d9b5073bba75779b201e977eeeba5ae1ad7f2b9b118669a7896918974631745f","expected_n_rows":3,"expected_columns":["o_orderstatus","n_orders"]}
{"id":"tpch_seed_004_join","tables":{"customer":{"columns":{"c_custkey":"Int64","c_name":"Utf8","c_address":"Utf8","c_nationkey":"Int64","c_phone":"Utf8","c_acctbal":"Float64","c_mktsegment":"Utf8","c_comment":"Utf8"},"n_rows":1500},"nation":{"columns":{"n_nationkey":"Int64","n_name":"Utf8","n_regionkey":"Int64","n_comment":"Utf8"},"n_rows":25}},"question":"Return the first 20 customers (by name) with the nation they belong to.","reference_code":"result = (\n    customer\n    .join(nation, left_on=\"c_nationkey\", right_on=\"n_nationkey\")\n    .select([pl.col(\"c_name\"), pl.col(\"n_name\").alias(\"nation\")])\n    .sort(\"c_name\")\n    .head(20)\n)","tags":["join","select"],"difficulty":2,"expected_output_hash":"495cce8bb284498eda2082a40d068b1d7445161fd2f17b9da9314c7a2066b80c","expected_n_rows":20,"expected_columns":["c_name","nation"]}
{"id":"tpch_seed_005_revenue_by_nation_1994","tables":{"lineitem":{"columns":{"l_orderkey":"Int64","l_partkey":"Int64","l_suppkey":"Int64","l_linenumber":"Int64","l_quantity":"Float64","l_extendedprice":"Float64","l_discount":"Float64","l_tax":"Float64","l_returnflag":"Utf8","l_linestatus":"Utf8","l_shipdate":"Date","l_commitdate":"Date","l_receiptdate":"Date","l_shipinstruct":"Utf8","l_shipmode":"Utf8","l_comment":"Utf8"},"n_rows":60175},"orders":{"columns":{"o_orderkey":"Int64","o_custkey":"Int64","o_orderstatus":"Utf8","o_totalprice":"Float64","o_orderdate":"Date","o_orderpriority":"Utf8","o_clerk":"Utf8","o_shippriority":"Int64","o_comment":"Utf8"},"n_rows":15000},"customer":{"columns":{"c_custkey":"Int64","c_name":"Utf8","c_address":"Utf8","c_nationkey":"Int64","c_phone":"Utf8","c_acctbal":"Float64","c_mktsegment":"Utf8","c_comment":"Utf8"},"n_rows":1500},"nation":{"columns":{"n_nationkey":"Int64","n_name":"Utf8","n_regionkey":"Int64","n_comment":"Utf8"},"n_rows":25}},"question":"Total discounted revenue per nation for orders placed in 1994, sorted descending.","reference_code":"result = (\n    lineitem\n    .join(orders, left_on=\"l_orderkey\", right_on=\"o_orderkey\")\n    .join(customer, left_on=\"o_custkey\", right_on=\"c_custkey\")\n    .join(nation, left_on=\"c_nationkey\", right_on=\"n_nationkey\")\n    .filter(pl.col(\"o_orderdate\").is_between(pl.date(1994, 1, 1), pl.date(1994, 12, 31)))\n    .with_columns((pl.col(\"l_extendedprice\") * (1 - pl.col(\"l_discount\"))).alias(\"revenue\"))\n    .group_by(\"n_name\")\n    .agg(pl.col(\"revenue\").sum())\n    .sort(\"revenue\", descending=True)\n)","tags":["join","filter","groupby","agg","date"],"difficulty":4,"expected_output_hash":"f4476b25a5807098393fbe165920475c3b28310f031f1b315d8d9e1785565fa6","expected_n_rows":25,"expected_columns":["n_name","revenue"]}
{"id":"tpch_seed_006_q1_1995_count","tables":{"orders":{"columns":{"o_orderkey":"Int64","o_custkey":"Int64","o_orderstatus":"Utf8","o_totalprice":"Float64","o_orderdate":"Date","o_orderpriority":"Utf8","o_clerk":"Utf8","o_shippriority":"Int64","o_comment":"Utf8"},"n_rows":15000}},"question":"How many orders were placed in Q1 1995?","reference_code":"result = (\n    orders\n    .filter(pl.col(\"o_orderdate\").is_between(pl.date(1995, 1, 1), pl.date(1995, 3, 31)))\n    .select(pl.len().alias(\"q1_1995_orders\"))\n)","tags":["filter","date","agg"],"difficulty":2,"expected_output_hash":"a9c5ffc34da48b0abe242146185d187a6b8b372265f18813836eb450d3385b56","expected_n_rows":1,"expected_columns":["q1_1995_orders"]}
{"id":"tpch_seed_007_string_contains","tables":{"customer":{"columns":{"c_custkey":"Int64","c_name":"Utf8","c_address":"Utf8","c_nationkey":"Int64","c_phone":"Utf8","c_acctbal":"Float64","c_mktsegment":"Utf8","c_comment":"Utf8"},"n_rows":1500}},"question":"Return customer keys and names whose name contains 'Customer#0000001'.","reference_code":"result = (\n    customer\n    .filter(pl.col(\"c_name\").str.contains(\"Customer#0000001\"))\n    .select([\"c_custkey\", \"c_name\"])\n    .sort(\"c_custkey\")\n)","tags":["filter","string"],"difficulty":1,"expected_output_hash":"5bab21c59ed7d0568be71c1dbc8551bf17a6af1bc97534fc9f27b1430dfd101f","expected_n_rows":100,"expected_columns":["c_custkey","c_name"]}
{"id":"tpch_seed_008_window_rank","tables":{"customer":{"columns":{"c_custkey":"Int64","c_name":"Utf8","c_address":"Utf8","c_nationkey":"Int64","c_phone":"Utf8","c_acctbal":"Float64","c_mktsegment":"Utf8","c_comment":"Utf8"},"n_rows":1500}},"question":"For each nation, return the top 3 customers by account balance (dense rank).","reference_code":"result = (\n    customer\n    .with_columns(\n        pl.col(\"c_acctbal\")\n        .rank(method=\"dense\", descending=True)\n        .over(\"c_nationkey\")\n        .alias(\"rank_in_nation\")\n    )\n    .filter(pl.col(\"rank_in_nation\") <= 3)\n    .select([\"c_custkey\", \"c_name\", \"c_nationkey\", \"c_acctbal\", \"rank_in_nation\"])\n    .sort([\"c_nationkey\", \"rank_in_nation\", \"c_custkey\"])\n)","tags":["window","filter","sort"],"difficulty":3,"expected_output_hash":"ed4008e079e63f81c0134de1eddd0640438bad9b83f9c699da2c870b0e0c3826","expected_n_rows":75,"expected_columns":["c_custkey","c_name","c_nationkey","c_acctbal","rank_in_nation"]}
{"id":"tpch_seed_009_q3_like","tables":{"customer":{"columns":{"c_custkey":"Int64","c_name":"Utf8","c_address":"Utf8","c_nationkey":"Int64","c_phone":"Utf8","c_acctbal":"Float64","c_mktsegment":"Utf8","c_comment":"Utf8"},"n_rows":1500},"orders":{"columns":{"o_orderkey":"Int64","o_custkey":"Int64","o_orderstatus":"Utf8","o_totalprice":"Float64","o_orderdate":"Date","o_orderpriority":"Utf8","o_clerk":"Utf8","o_shippriority":"Int64","o_comment":"Utf8"},"n_rows":15000},"lineitem":{"columns":{"l_orderkey":"Int64","l_partkey":"Int64","l_suppkey":"Int64","l_linenumber":"Int64","l_quantity":"Float64","l_extendedprice":"Float64","l_discount":"Float64","l_tax":"Float64","l_returnflag":"Utf8","l_linestatus":"Utf8","l_shipdate":"Date","l_commitdate":"Date","l_receiptdate":"Date","l_shipinstruct":"Utf8","l_shipmode":"Utf8","l_comment":"Utf8"},"n_rows":60175}},"question":"For BUILDING segment customers with orders before 1995-03-15 and line items shipped after 1995-03-15, return the top 10 orders by summed discounted revenue (TPC-H Q3).","reference_code":"result = (\n    customer\n    .filter(pl.col(\"c_mktsegment\") == \"BUILDING\")\n    .join(orders, left_on=\"c_custkey\", right_on=\"o_custkey\")\n    .filter(pl.col(\"o_orderdate\") < pl.date(1995, 3, 15))\n    .join(lineitem, left_on=\"o_orderkey\", right_on=\"l_orderkey\")\n    .filter(pl.col(\"l_shipdate\") > pl.date(1995, 3, 15))\n    .with_columns((pl.col(\"l_extendedprice\") * (1 - pl.col(\"l_discount\"))).alias(\"revenue\"))\n    .group_by([\"o_orderkey\", \"o_orderdate\", \"o_shippriority\"])\n    .agg(pl.col(\"revenue\").sum())\n    .sort([\"revenue\", \"o_orderdate\"], descending=[True, False])\n    .head(10)\n)","tags":["join","filter","groupby","agg","sort","limit"],"difficulty":5,"expected_output_hash":"eff4fae677ca9eb2f85b8acef25609025a64a0c0e1e6ea6f30d8748e9b64dd4e","expected_n_rows":10,"expected_columns":["o_orderkey","o_orderdate","o_shippriority","revenue"]}
{"id":"tpch_seed_010_semi_join","tables":{"part":{"columns":{"p_partkey":"Int64","p_name":"Utf8","p_mfgr":"Utf8","p_brand":"Utf8","p_type":"Utf8","p_size":"Int64","p_container":"Utf8","p_retailprice":"Float64","p_comment":"Utf8"},"n_rows":2000},"partsupp":{"columns":{"ps_partkey":"Int64","ps_suppkey":"Int64","ps_availqty":"Int64","ps_supplycost":"Float64","ps_comment":"Utf8"},"n_rows":8000},"supplier":{"columns":{"s_suppkey":"Int64","s_name":"Utf8","s_address":"Utf8","s_nationkey":"Int64","s_phone":"Utf8","s_acctbal":"Float64","s_comment":"Utf8"},"n_rows":100},"nation":{"columns":{"n_nationkey":"Int64","n_name":"Utf8","n_regionkey":"Int64","n_comment":"Utf8"},"n_rows":25}},"question":"Return the first 20 parts (by partkey) that have at least one supplier based in ALGERIA.","reference_code":"algerian_parts = (\n    partsupp\n    .join(supplier, left_on=\"ps_suppkey\", right_on=\"s_suppkey\")\n    .join(nation, left_on=\"s_nationkey\", right_on=\"n_nationkey\")\n    .filter(pl.col(\"n_name\") == \"ALGERIA\")\n    .select(\"ps_partkey\")\n)\nresult = (\n    part\n    .join(algerian_parts, left_on=\"p_partkey\", right_on=\"ps_partkey\", how=\"semi\")\n    .select([\"p_partkey\", \"p_name\"])\n    .sort(\"p_partkey\")\n    .head(20)\n)","tags":["join","semi_join","filter"],"difficulty":4,"expected_output_hash":"440c967cc638e3a6e485165d75908198a0ac56b6f8ae7ebd9da0c674d77d21cf","expected_n_rows":20,"expected_columns":["p_partkey","p_name"]}
