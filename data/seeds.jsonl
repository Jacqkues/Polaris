{"id":"tpch_seed_008_window_rank","tables":{"customer":{"columns":{"c_custkey":"Int64","c_name":"Utf8","c_address":"Utf8","c_nationkey":"Int64","c_phone":"Utf8","c_acctbal":"Float64","c_mktsegment":"Utf8","c_comment":"Utf8"},"n_rows":1500}},"question":"For each nation, return the top 3 customers by account balance (dense rank).","reference_code":"result = (\n    customer\n    .with_columns(\n        pl.col(\"c_acctbal\")\n        .rank(method=\"dense\", descending=True)\n        .over(\"c_nationkey\")\n        .alias(\"rank_in_nation\")\n    )\n    .filter(pl.col(\"rank_in_nation\") <= 3)\n    .select([\"c_custkey\", \"c_name\", \"c_nationkey\", \"c_acctbal\", \"rank_in_nation\"])\n    .sort([\"c_nationkey\", \"rank_in_nation\", \"c_custkey\"])\n)","tags":["window","filter","sort"],"difficulty":3,"expected_output_hash":"ed4008e079e63f81c0134de1eddd0640438bad9b83f9c699da2c870b0e0c3826","expected_n_rows":75,"expected_columns":["c_custkey","c_name","c_nationkey","c_acctbal","rank_in_nation"]}
{"id":"tpch_seed_009_q3_like","tables":{"customer":{"columns":{"c_custkey":"Int64","c_name":"Utf8","c_address":"Utf8","c_nationkey":"Int64","c_phone":"Utf8","c_acctbal":"Float64","c_mktsegment":"Utf8","c_comment":"Utf8"},"n_rows":1500},"orders":{"columns":{"o_orderkey":"Int64","o_custkey":"Int64","o_orderstatus":"Utf8","o_totalprice":"Float64","o_orderdate":"Date","o_orderpriority":"Utf8","o_clerk":"Utf8","o_shippriority":"Int64","o_comment":"Utf8"},"n_rows":15000},"lineitem":{"columns":{"l_orderkey":"Int64","l_partkey":"Int64","l_suppkey":"Int64","l_linenumber":"Int64","l_quantity":"Float64","l_extendedprice":"Float64","l_discount":"Float64","l_tax":"Float64","l_returnflag":"Utf8","l_linestatus":"Utf8","l_shipdate":"Date","l_commitdate":"Date","l_receiptdate":"Date","l_shipinstruct":"Utf8","l_shipmode":"Utf8","l_comment":"Utf8"},"n_rows":60175}},"question":"For BUILDING segment customers with orders before 1995-03-15 and line items shipped after 1995-03-15, return the top 10 orders by summed discounted revenue (TPC-H Q3).","reference_code":"result = (\n    customer\n    .filter(pl.col(\"c_mktsegment\") == \"BUILDING\")\n    .join(orders, left_on=\"c_custkey\", right_on=\"o_custkey\")\n    .filter(pl.col(\"o_orderdate\") < pl.date(1995, 3, 15))\n    .join(lineitem, left_on=\"o_orderkey\", right_on=\"l_orderkey\")\n    .filter(pl.col(\"l_shipdate\") > pl.date(1995, 3, 15))\n    .with_columns((pl.col(\"l_extendedprice\") * (1 - pl.col(\"l_discount\"))).alias(\"revenue\"))\n    .group_by([\"o_orderkey\", \"o_orderdate\", \"o_shippriority\"])\n    .agg(pl.col(\"revenue\").sum())\n    .sort([\"revenue\", \"o_orderdate\"], descending=[True, False])\n    .head(10)\n)","tags":["join","filter","groupby","agg","sort","limit"],"difficulty":5,"expected_output_hash":"eff4fae677ca9eb2f85b8acef25609025a64a0c0e1e6ea6f30d8748e9b64dd4e","expected_n_rows":10,"expected_columns":["o_orderkey","o_orderdate","o_shippriority","revenue"]}
{"id":"tpch_seed_010_semi_join","tables":{"part":{"columns":{"p_partkey":"Int64","p_name":"Utf8","p_mfgr":"Utf8","p_brand":"Utf8","p_type":"Utf8","p_size":"Int64","p_container":"Utf8","p_retailprice":"Float64","p_comment":"Utf8"},"n_rows":2000},"partsupp":{"columns":{"ps_partkey":"Int64","ps_suppkey":"Int64","ps_availqty":"Int64","ps_supplycost":"Float64","ps_comment":"Utf8"},"n_rows":8000},"supplier":{"columns":{"s_suppkey":"Int64","s_name":"Utf8","s_address":"Utf8","s_nationkey":"Int64","s_phone":"Utf8","s_acctbal":"Float64","s_comment":"Utf8"},"n_rows":100},"nation":{"columns":{"n_nationkey":"Int64","n_name":"Utf8","n_regionkey":"Int64","n_comment":"Utf8"},"n_rows":25}},"question":"Return the first 20 parts (by partkey) that have at least one supplier based in ALGERIA.","reference_code":"algerian_parts = (\n    partsupp\n    .join(supplier, left_on=\"ps_suppkey\", right_on=\"s_suppkey\")\n    .join(nation, left_on=\"s_nationkey\", right_on=\"n_nationkey\")\n    .filter(pl.col(\"n_name\") == \"ALGERIA\")\n    .select(\"ps_partkey\")\n)\nresult = (\n    part\n    .join(algerian_parts, left_on=\"p_partkey\", right_on=\"ps_partkey\", how=\"semi\")\n    .select([\"p_partkey\", \"p_name\"])\n    .sort(\"p_partkey\")\n    .head(20)\n)","tags":["join","semi_join","filter"],"difficulty":4,"expected_output_hash":"440c967cc638e3a6e485165d75908198a0ac56b6f8ae7ebd9da0c674d77d21cf","expected_n_rows":20,"expected_columns":["p_partkey","p_name"]}
