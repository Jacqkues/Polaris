{"id":"tpch_seed_022_left_join","tables":{"nation":{"columns":{"n_nationkey":"Int64","n_name":"Utf8","n_regionkey":"Int64","n_comment":"Utf8"},"n_rows":25},"region":{"columns":{"r_regionkey":"Int64","r_name":"Utf8","r_comment":"Utf8"},"n_rows":5}},"question":"First 5 nations with their region name, left-joined on region key.","reference_code":"result = (\n    nation\n    .join(region, left_on=\"n_regionkey\", right_on=\"r_regionkey\", how=\"left\")\n    .select([pl.col(\"n_name\"), pl.col(\"r_name\").alias(\"region\")])\n    .sort(\"n_name\")\n    .head(5)\n)","tags":["join_left","select"],"difficulty":2,"expected_output_hash":"a321dffcfc7fefc9f83e35a9baeb90e2eb9f289e812c65983369f4a70370a9a8","expected_n_rows":5,"expected_columns":["n_name","region"]}
{"id":"tpch_seed_023_three_way_join_arith","tables":{"lineitem":{"columns":{"l_orderkey":"Int64","l_partkey":"Int64","l_suppkey":"Int64","l_linenumber":"Int64","l_quantity":"Float64","l_extendedprice":"Float64","l_discount":"Float64","l_tax":"Float64","l_returnflag":"Utf8","l_linestatus":"Utf8","l_shipdate":"Date","l_commitdate":"Date","l_receiptdate":"Date","l_shipinstruct":"Utf8","l_shipmode":"Utf8","l_comment":"Utf8"},"n_rows":60175},"orders":{"columns":{"o_orderkey":"Int64","o_custkey":"Int64","o_orderstatus":"Utf8","o_totalprice":"Float64","o_orderdate":"Date","o_orderpriority":"Utf8","o_clerk":"Utf8","o_shippriority":"Int64","o_comment":"Utf8"},"n_rows":15000},"customer":{"columns":{"c_custkey":"Int64","c_name":"Utf8","c_address":"Utf8","c_nationkey":"Int64","c_phone":"Utf8","c_acctbal":"Float64","c_mktsegment":"Utf8","c_comment":"Utf8"},"n_rows":1500}},"question":"Top 10 lineitems (by price * (1-disc) * (1+tax)) for AUTOMOBILE customers.","reference_code":"result = (\n    lineitem\n    .join(orders, left_on=\"l_orderkey\", right_on=\"o_orderkey\")\n    .join(customer, left_on=\"o_custkey\", right_on=\"c_custkey\")\n    .filter(pl.col(\"c_mktsegment\") == \"AUTOMOBILE\")\n    .with_columns(\n        (pl.col(\"l_extendedprice\") * (1 - pl.col(\"l_discount\")) * (1 + pl.col(\"l_tax\")))\n        .alias(\"gross\")\n    )\n    .select([\"c_name\", \"l_orderkey\", \"gross\"])\n    .sort(\"gross\", descending=True)\n    .head(10)\n)","tags":["join","filter","arith","sort","limit"],"difficulty":4,"expected_output_hash":"f55cc8f42dbed1dca7aa2c657bfa877e7db3d26cfab71746d20fd1ffb629d5aa","expected_n_rows":10,"expected_columns":["c_name","l_orderkey","gross"]}
{"id":"tpch_seed_024_bool_and_date","tables":{"lineitem":{"columns":{"l_orderkey":"Int64","l_partkey":"Int64","l_suppkey":"Int64","l_linenumber":"Int64","l_quantity":"Float64","l_extendedprice":"Float64","l_discount":"Float64","l_tax":"Float64","l_returnflag":"Utf8","l_linestatus":"Utf8","l_shipdate":"Date","l_commitdate":"Date","l_receiptdate":"Date","l_shipinstruct":"Utf8","l_shipmode":"Utf8","l_comment":"Utf8"},"n_rows":60175}},"question":"Count lineitems shipped in 1994 with quantity > 30 and discount < 0.05.","reference_code":"result = (\n    lineitem\n    .filter(\n        (pl.col(\"l_shipdate\").is_between(pl.date(1994, 1, 1), pl.date(1994, 12, 31)))\n        & (pl.col(\"l_quantity\") > 30)\n        & (pl.col(\"l_discount\") < 0.05)\n    )\n    .select(pl.len().alias(\"n\"))\n)","tags":["filter","bool_and","date"],"difficulty":3,"expected_output_hash":"a3ee46b06869377ca94201237598fc18ac169652a9384a8e3fef52aba63e53e8","expected_n_rows":1,"expected_columns":["n"]}
{"id":"tpch_seed_025_dt_month_filter","tables":{"orders":{"columns":{"o_orderkey":"Int64","o_custkey":"Int64","o_orderstatus":"Utf8","o_totalprice":"Float64","o_orderdate":"Date","o_orderpriority":"Utf8","o_clerk":"Utf8","o_shippriority":"Int64","o_comment":"Utf8"},"n_rows":15000}},"question":"Count March orders across all years.","reference_code":"result = (\n    orders\n    .with_columns(pl.col(\"o_orderdate\").dt.month().alias(\"month\"))\n    .filter(pl.col(\"month\") == 3)\n    .group_by(\"month\")\n    .agg(pl.len().alias(\"n_march\"))\n)","tags":["date","dt_month","filter","groupby"],"difficulty":3,"expected_output_hash":"998b1e6aac3e8978a5da4fe9359c4c0638ecbc95caae10e19bf79277abbb1292","expected_n_rows":1,"expected_columns":["month","n_march"]}
